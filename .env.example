# --- Frontend (Vite) ---
# Al copiar a .env.local: usá la URL y la anon key REALES (Supabase → Project Settings → API).
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Mail(s) con acceso al panel /control (separados por coma si hay varios). Debe coincidir con ADMIN_EMAILS.
VITE_ADMIN_EMAILS=admin@tudominio.com

# Backend (API /api en Vercel o npm run dev)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=

# URL pública del sitio (success_url del checkout Polar, origen general)
APP_PUBLIC_URL=http://localhost:5173
# Links de invitación por mail — SIEMPRE producción en Vercel (nunca localhost)
ACTIVATION_PUBLIC_URL=https://programaberich.fit

# Polar (checkout del quiz + webhook post-compra)
# Dashboard: https://polar.sh/dashboard — arriba a la derecha podés cambiar Sandbox / Production
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
# production | sandbox — debe coincidir con el token (token de sandbox no funciona en production)
POLAR_ENVIRONMENT=production

# Precio base USD 49 en api/_lib/programPrice.ts.
# En Polar: producto one-time 49 USD + monedas extra en el producto (ARS, UYU, MXN, etc.).

PRODUCT_SLUG=berich-completo

# Mails post-compra (Resend). Ver docs/DOMAIN_SETUP.md para verificar programaberich.fit
RESEND_API_KEY=
RESEND_FROM=Programa Berich <hola@programaberich.fit>
