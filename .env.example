# --- Frontend (Vite) ---
# Al copiar a .env.local: usá la URL y la anon key REALES (Supabase → Project Settings → API).
# Los valores https://xxxx.supabase.co / eyJ... de abajo son solo plantilla y provocan "Failed to fetch" al login.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Mail(s) con acceso al panel /control (separados por coma si hay varios).
VITE_ADMIN_EMAILS=admin@tudominio.com

# --- API serverless (Vercel / `vercel dev`) — NO usar prefijo VITE ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
ADMIN_EMAILS=admin@tudominio.com

# URL pública del sitio (link en mails de invitación). En Vercel suele inferirse VERCEL_URL.
APP_PUBLIC_URL=https://tu-dominio.com

# Dodo Payments (checkout del quiz + webhook post-compra)
# Dashboard → Developer → API Keys / Webhooks
DODO_PAYMENTS_API_KEY=
DODO_PRODUCT_ID=
DODO_WEBHOOK_SECRET=
# test (default) o live
DODO_PAYMENTS_ENVIRONMENT=test

# Producto lógico (debe coincidir con rutas /programa/:slug y con product_slug en DB)
PRODUCT_SLUG=berich-completo

# Resend (opcional: si falta, el webhook igual crea invitación y loguea el link en consola)
RESEND_API_KEY=
# Ej: "Berich <notificaciones@tudominio.com>" (dominio verificado en Resend)
RESEND_FROM=
