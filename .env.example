# --- Frontend (Vite) ---
# Con `npm run dev`, /programa abre en modo previsualización (sin login). En build de producción siempre exige alumno.
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_ADMIN_EMAILS=admin@tudominio.com

# --- API serverless (Vercel / `vercel dev`) — NO usar prefijo VITE ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
ADMIN_EMAILS=admin@tudominio.com

# URL pública del sitio (link en mails de invitación). En Vercel suele inferirse VERCEL_URL.
APP_PUBLIC_URL=https://tu-dominio.com

# Shopify: webhook "orders/paid" apuntando a /api/shopify/orders-paid
SHOPIFY_WEBHOOK_SECRET=

# Producto lógico (debe coincidir con rutas /programa/:slug y con product_slug en DB)
PRODUCT_SLUG=berich-completo

# Resend (opcional: si falta, el webhook igual crea invitación y loguea el link en consola)
RESEND_API_KEY=
# Ej: "Berich <notificaciones@tudominio.com>" (dominio verificado en Resend)
RESEND_FROM=
