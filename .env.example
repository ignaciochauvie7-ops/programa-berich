# URLs públicas (producción)
APP_PUBLIC_URL=https://programaberich.fit
ACTIVATION_PUBLIC_URL=https://programaberich.fit

# Polar (checkout + webhook post-compra)
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_SUBSCRIPTION_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
