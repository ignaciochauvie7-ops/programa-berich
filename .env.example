# --- Frontend (Vite) ---
# Al copiar a .env.local: usá la URL y la anon key REALES (Supabase → Project Settings → API).
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Mail(s) con acceso al panel /control (separados por coma si hay varios).
VITE_ADMIN_EMAILS=admin@tudominio.com

# Backend (API /api en Vercel o npm run dev)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=

APP_PUBLIC_URL=http://localhost:5173
# Links de invitación por mail (producción aunque desarrolles en localhost)
ACTIVATION_PUBLIC_URL=https://programa-berich.vercel.app

# Dodo Payments (checkout del quiz + webhook post-compra)
DODO_PAYMENTS_API_KEY=
DODO_PRODUCT_ID=
DODO_WEBHOOK_SECRET=
DODO_PAYMENTS_ENVIRONMENT=test

PRODUCT_SLUG=berich-completo

# Opcional
RESEND_API_KEY=
RESEND_FROM=
