# --- Frontend (Vite) ---
# Al copiar a .env.local: usá la URL y la anon key REALES (Supabase → Project Settings → API).
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Mail(s) con acceso al panel /control (separados por coma si hay varios). Debe coincidir con ADMIN_EMAILS.
VITE_ADMIN_EMAILS=admin@tudominio.com

# Backend (API /api en Vercel o npm run dev)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=

# URL pública del sitio (return_url del checkout Dodo, origen general)
APP_PUBLIC_URL=http://localhost:5173
# Links de invitación por mail — SIEMPRE producción en Vercel (nunca localhost)
ACTIVATION_PUBLIC_URL=https://programa-berich.vercel.app

# Dodo Payments (checkout del quiz + webhook post-compra)
DODO_PAYMENTS_API_KEY=
DODO_PRODUCT_ID=
DODO_WEBHOOK_SECRET=
# test | live — debe coincidir con el dashboard y la API key
DODO_PAYMENTS_ENVIRONMENT=test

# Precio: el quiz muestra conversión desde PROGRAM_USD_PRICE (=49) en api/_lib/programPrice.ts.
# El cobro real lo define el producto DODO_PRODUCT_ID en el dashboard de Dodo (debe ser 49 USD).
# Adaptive Currency en Dodo puede diferir levemente del número mostrado en el quiz.

PRODUCT_SLUG=berich-completo

# Opcional
RESEND_API_KEY=
RESEND_FROM=
